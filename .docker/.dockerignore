# .dockerignore — keep the image build context small. The image
# installs `myco[mcp]` from PyPI, so none of the local source tree
# needs to enter the build context. Only Dockerfile itself does.

# VCS
.git
.gitignore
.github

# Python build / test artifacts
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
coverage.*
htmlcov
build
dist
*.egg-info

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Myco substrate state + source tree (unused in this image — see
# Dockerfile for why we install from PyPI rather than COPY).
# v0.8.5 — paths aligned with v0.8.4 root-cleanup (hidden-prefixed dirs).
src
.tests
.docs
.scripts
.myco
.claude
.claude-plugin
.cowork-plugin
.plugin
.meta
.mcp.json

# Doc + changelog files
*.md
pyproject.toml
LICENSE
