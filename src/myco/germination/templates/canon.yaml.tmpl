# _canon.yaml — authored by `myco germinate` on $generated_at
# Schema: docs/architecture/L1_CONTRACT/canon_schema.md
schema_version: "1"
contract_version: "$contract_version"
# v0.5.8: germinate stamps synced_contract_version in lockstep with
# contract_version so a fresh substrate starts in a synced state.
# Drift detection in hunger + the DC3 migration dimension (v0.5.8)
# compare canon.contract_version vs synced_contract_version; missing
# synced = permanent no-drift which hides every future upgrade need.
synced_contract_version: "$contract_version"

identity:
  substrate_id: "$substrate_id"
  tags: $tags_flow
  entry_point: "$entry_point"

system:
  write_surface:
    allowed:
      - "_canon.yaml"
      - "notes/**"
      - "docs/**"
      - "src/**"
  hard_contract:
    rules_ref: "docs/architecture/L1_CONTRACT/protocol.md"
    rule_count: 7
  # v0.5.6 (L0 principle 1 enforcement): declares whether this
  # substrate opts out of the "Agent calls LLM, substrate does
  # not" invariant. Default true. MP1 dimension cross-checks
  # against kernel scans.
  no_llm_in_substrate: true

versioning:
  package_version_ref: "src/myco/__init__.py"
  pyproject_dynamic: true

lint:
  categories:
    - mechanical
    - shipped
    - metabolic
    - semantic
  exit_policy:
    default: "mechanical:critical,shipped:critical,metabolic:never,semantic:never"
  skeleton_downgrade:
    marker: ".myco_state/autoseeded.txt"
    affected_dimensions: ["L0"]

subsystems:
  # Fresh substrates declare only the doctrine pointers. `package:` is
  # opt-in at v0.5+ and only appears in substrates whose subsystems
  # correspond to code packages under this root (e.g. Myco's self-
  # substrate). MF1 validates `package:` when present but treats its
  # absence as "this substrate uses subsystems for documentation only".
  germination:
    doc: "docs/architecture/L2_DOCTRINE/genesis.md"
  ingestion:
    doc: "docs/architecture/L2_DOCTRINE/ingestion.md"
  digestion:
    doc: "docs/architecture/L2_DOCTRINE/digestion.md"
  circulation:
    doc: "docs/architecture/L2_DOCTRINE/circulation.md"
  homeostasis:
    doc: "docs/architecture/L2_DOCTRINE/homeostasis.md"

commands:
  manifest_ref: "src/myco/surface/manifest.yaml"

metrics:
  test_count: 0

waves:
  current: 1
  log_ref: "docs/contract_changelog.md"
