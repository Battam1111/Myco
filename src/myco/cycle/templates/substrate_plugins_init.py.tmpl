"""Substrate-local Myco plugin package.

Generated by ``myco ramify`` the first time a substrate-local plugin
is scaffolded. Imports every subpackage (dimensions/, adapters/,
handlers/) for its registration side-effects so that when
``Substrate.load()`` imports this package, the kernel's registries
are fully populated before any verb runs.

Fungal-vocabulary craft:
``docs/primordia/v0_5_3_fungal_vocabulary_craft_2026-04-17.md``.

Each subpackage is imported under ``try/except`` so a missing one
(e.g. a substrate that ships only a custom dimension, no adapters) is
fine. A broken one surfaces on the substrate as a
``local_plugin_errors`` entry and MF2 reports it next run.
"""

from __future__ import annotations


try:
    from . import dimensions as _dimensions  # noqa: F401
except Exception:
    pass

try:
    from . import adapters as _adapters  # noqa: F401
except Exception:
    pass

try:
    from . import handlers as _handlers  # noqa: F401
except Exception:
    pass
