{
  "permissions": {
    "allow": [
      "Bash(python -m myco hunger*)",
      "Bash(python -m myco senesce*)",
      "Bash(python -m myco immune*)",
      "Bash(python -m myco sense*)",
      "Bash(python -m myco forage*)",
      "Bash(python -m myco eat*)",
      "Bash(python -m myco digest*)",
      "Bash(python -m myco assimilate*)",
      "Bash(python -m myco traverse*)",
      "Bash(python -m myco propagate*)",
      "Bash(python -m myco germinate*)",
      "Bash(python -m myco molt*)",
      "Bash(python -m myco fruit*)",
      "Bash(python -m myco winnow*)",
      "Bash(python -m myco ramify*)",
      "Bash(python -m myco graft*)",
      "Bash(python -m myco brief*)",
      "Bash(python -m myco excrete*)",
      "Bash(python -m myco intake*)",
      "Bash(python -m myco sporulate*)",
      "Bash(pytest*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m myco --json --project-dir \"$CLAUDE_PROJECT_DIR\" hunger"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m myco --json --project-dir \"$CLAUDE_PROJECT_DIR\" senesce"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m myco --json --project-dir \"$CLAUDE_PROJECT_DIR\" senesce --quick"
          }
        ]
      }
    ]
  }
}
